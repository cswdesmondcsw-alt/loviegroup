{
  "kind": "collectionType",
  "collectionName": "tenants",
  "info": {
    "singularName": "tenant",
    "pluralName": "tenants",
    "displayName": "Tenant"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "tenant_id": {
      "type": "uid",
      "targetField": "username",
      "required": true
    },
    "entity_type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "user",
        "provider"
      ]
    },
    "entity_label": {
      "type": "string",
      "required": true
    },
    "cloud_rank": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "user",
        "admin",
        "manager",
        "executive"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "private": true
    },
    "username": {
      "type": "string",
      "required": true
    },
    "country_code": {
      "type": "integer"
    },
    "mobile_no": {
      "type": "biginteger"
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": false
    },
    "password": {
      "type": "password",
      "required": true
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "resetPasswordToken": {
      "type": "string"
    },
    "confirmationToken": {
      "type": "string"
    },
    "confirmed": {
      "type": "boolean"
    },
    "blocked": {
      "type": "boolean"
    }
  }
}
